<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
   PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
   "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spoon.dao.sellerDAO">
   <select id="listDao" resultType="com.spoon.dto.sellerDTO">
      select * from seller order by s_no asc
   </select>
   <select id="viewDao" resultType="com.spoon.dto.sellerDTO">
      select * from seller where s_no = #{param1}
   </select>
   <select id="getSellerByMemberNo" resultType="com.spoon.dto.sellerDTO">
    SELECT s_no, s_name, s_bn, s_num, s_temp, m_no
    FROM seller
    WHERE m_no = #{m_no}
</select>
    <select id="findByMemberNo" resultType="com.spoon.dto.sellerDTO">
        SELECT *
        FROM seller
        WHERE m_no = #{m_no}
    </select>
   
   <insert id="writeDao">
    insert into seller values (seq_seller.nextval,#{s_name},#{s_num},#{s_bn},'USER',#{m_no})
   </insert>

   <update id="updateDao">
      update seller set s_name=#{s_name},s_bn=#{s_bn},s_num=#{s_num},s_temp=#{s_temp} where s_no=#{s_no}
   </update>
   <delete id="deleteDao">
      delete from seller where s_no=#{param1} 
   </delete>
</mapper>