<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spoon.dao.cartDAO">
	<select id="listDao" resultType="com.spoon.dto.cartDTO">
		select * from cart where m_no =#{m_no} 
	</select>
	<select id="viewDao" resultType="com.spoon.dto.cartDTO">
		select * from cart where c_no = #{param1}
	</select>
	<select id="findByiNo" resultType="com.spoon.dto.cartDTO">
		select * from cart where i_no = #{i_no}
	</select>
	
	<insert id="writeDao">
		insert into cart values (seq_cart.nextval,#{i_no},#{c_name},#{c_count},#{c_price},#{m_no})
	</insert>
	<update id="updateDao">
		update cart set c_count=#{c_count},c_price=#{c_price} where c_no=#{c_no}
	</update>
	<delete id="deleteDao">
		delete from cart where c_no=#{param1} 
	</delete>
	
	<delete id="cleancart">
		delete from cart where m_no=#{m_no}
	</delete>
	<select id="paySummary" resultType="com.spoon.dto.CartPaySummaryDTO">
        SELECT
            NVL(SUM(c_price * c_count), 0) AS totalAmount,
            NVL(SUM(c_count), 0)          AS itemCount,
            NVL(MIN(c_name), '장바구니')  AS firstName
        FROM cart
        WHERE m_no = #{param1}
    </select>
</mapper>